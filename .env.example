# ── Database ──────────────────────────────────────────────────────────────────
# PgBouncer pooled — runtime ONLY
DATABASE_URL="postgresql://postgres.YOURREF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10"
# Direct — migrations ONLY (never use in app code)
DIRECT_URL="postgresql://postgres.YOURREF:PASSWORD@aws-0-eu-central-1.supabase.com:5432/postgres"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="REPLACE_WITH_256BIT_RANDOM_SECRET"
JWT_EXPIRY_SECONDS=604800

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://default:PASSWORD@your-upstash-host.upstash.io:6379"

# ── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_FLASH_MODEL="gemini-1.5-flash"
GEMINI_PRO_MODEL="gemini-1.5-pro"
GEMINI_TIMEOUT_MS=5000

# ── SMTP ──────────────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="noreply@gaaffilee.et"
SMTP_PASS="your-smtp-password"
EMAIL_FROM="Gaaffilee <noreply@gaaffilee.et>"

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CORS_ALLOWED_ORIGINS="http://localhost:3000,https://gaaffilee.et"

# ── Rate Limits ───────────────────────────────────────────────────────────────
AI_CALLS_PER_SESSION=3
THROTTLER_TTL=60000
THROTTLER_LIMIT=100

# ── Seed (only needed for prisma:seed) ────────────────────────────────────────
SEED_ADMIN_HASH="$2b$12$REPLACE_WITH_BCRYPT_HASH_OF_ADMIN_PASSWORD"
