// prisma/schema.prisma — Gaaffilee Qorumsa Barnootaa v1.0

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── ENUMS ──────────────────────────────────────────────────────────────────────

enum UserRole {
  student
  teacher
  admin
}

enum StreamSlug {
  natural
  social
}

enum StudyMode {
  year_based
  chapter_based
  exam_simulation
}

enum QuizMode {
  practice
  timed
}

enum SessionStatus {
  in_progress
  completed
  abandoned
}

enum Difficulty {
  easy
  medium
  hard
}

enum QuestionStatus {
  active
  draft
  archived
}

// ── STREAMS ────────────────────────────────────────────────────────────────────

model Stream {
  id         String     @id @default(cuid())
  name       String
  slug       StreamSlug @unique
  color_hex  String     @db.VarChar(7)
  created_at DateTime   @default(now())

  subjects Subject[]

  @@map("streams")
}

// ── SUBJECTS ───────────────────────────────────────────────────────────────────

model Subject {
  id         String   @id @default(cuid())
  stream_id  String
  name       String
  slug       String   @unique
  grade_min  Int
  grade_max  Int
  created_at DateTime @default(now())

  stream   Stream        @relation(fields: [stream_id], references: [id])
  chapters Chapter[]
  questions Question[]
  sessions QuizSession[]

  @@index([stream_id])
  @@map("subjects")
}

// ── CHAPTERS ───────────────────────────────────────────────────────────────────

model Chapter {
  id             String   @id @default(cuid())
  subject_id     String
  grade          Int
  chapter_number Int
  title          String
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  subject   Subject    @relation(fields: [subject_id], references: [id])
  questions Question[]

  @@unique([subject_id, grade, chapter_number])
  @@index([subject_id, grade])
  @@map("chapters")
}

// ── QUESTIONS ──────────────────────────────────────────────────────────────────

model Question {
  id             String         @id @default(cuid())
  subject_id     String
  chapter_id     String
  grade          Int
  exam_year      String         @db.VarChar(12)
  question_text  String         @db.Text
  option_a       String         @db.VarChar(500)
  option_b       String         @db.VarChar(500)
  option_c       String         @db.VarChar(500)
  option_d       String         @db.VarChar(500)
  correct_answer String         @db.VarChar(1)
  explanation    String?        @db.Text
  difficulty     Difficulty     @default(medium)
  status         QuestionStatus @default(active)
  created_by     String?
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt

  subject Subject      @relation(fields: [subject_id], references: [id])
  chapter Chapter      @relation(fields: [chapter_id], references: [id])
  answers QuizAnswer[]

  @@index([subject_id, grade, status], name: "idx_q_sub_grade_status")
  @@index([subject_id, chapter_id, status], name: "idx_q_sub_chapter_status")
  @@index([subject_id, exam_year, status], name: "idx_q_sub_year_status")
  @@index([subject_id, grade, chapter_id, status], name: "idx_q_sub_grade_ch_status")
  @@map("questions")
}

// ── USERS ──────────────────────────────────────────────────────────────────────

model User {
  id                     String      @id @default(cuid())
  name                   String      @db.VarChar(100)
  email                  String      @unique @db.VarChar(255)
  password_hash          String      @db.VarChar(60)
  role                   UserRole    @default(student)
  grade                  Int?
  stream                 StreamSlug?
  school                 String?     @db.VarChar(200)
  is_active              Boolean     @default(true)
  otp_hash               String?     @db.VarChar(64)
  otp_expires_at         DateTime?
  otp_attempts           Int         @default(0)
  reset_token_hash       String?     @db.VarChar(64)
  reset_token_expires_at DateTime?
  created_at             DateTime    @default(now())
  updated_at             DateTime    @updatedAt

  sessions QuizSession[]

  @@index([role])
  @@map("users")
}

// ── QUIZ SESSIONS ──────────────────────────────────────────────────────────────

model QuizSession {
  id                     String        @id @default(cuid())
  user_id                String
  subject_id             String
  chapter_id             String?
  grade                  Int
  exam_year              String?       @db.VarChar(12)
  study_mode             StudyMode
  quiz_mode              QuizMode
  status                 SessionStatus @default(in_progress)
  total_questions        Int
  ai_calls_used          Int           @default(0)
  started_at             DateTime      @default(now())
  score                  Int?
  percentage             Float?
  band                   String?       @db.VarChar(20)
  total_time_sec         Int?
  weakness_report_status String?       @db.VarChar(10)
  weakness_report        String?       @db.Text
  completed_at           DateTime?
  created_at             DateTime      @default(now())
  updated_at             DateTime      @updatedAt

  user    User         @relation(fields: [user_id], references: [id])
  subject Subject      @relation(fields: [subject_id], references: [id])
  answers QuizAnswer[]

  @@index([user_id], name: "idx_sessions_user")
  @@index([user_id, subject_id], name: "idx_sessions_user_subject")
  @@index([user_id, status], name: "idx_sessions_user_status")
  @@index([subject_id, status], name: "idx_sessions_subject_status")
  @@map("quiz_sessions")
}

// ── QUIZ ANSWERS ───────────────────────────────────────────────────────────────

model QuizAnswer {
  id             String   @id @default(cuid())
  session_id     String
  question_id    String
  selected       String?  @db.VarChar(1)
  is_correct     Boolean
  is_skipped     Boolean  @default(false)
  is_timed_out   Boolean  @default(false)
  ai_hint_used   Boolean  @default(false)
  time_taken_sec Int      @default(0)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  session  QuizSession @relation(fields: [session_id], references: [id])
  question Question    @relation(fields: [question_id], references: [id])

  @@unique([session_id, question_id], name: "uq_answer_session_question")
  @@index([session_id], name: "idx_answers_session")
  @@index([question_id], name: "idx_answers_question")
  @@map("quiz_answers")
}
